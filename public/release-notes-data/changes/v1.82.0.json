        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_routing_queue",
            "attribute": "email_media_settings.auto_answer_alert_tone_seconds",
            "change": "added",
            "summary": "Optional duration in seconds to play the alerting tone for auto-answer email interactions."
        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_routing_queue",
            "attribute": "email_media_settings.manual_answer_alert_tone_seconds",
            "change": "added",
            "summary": "Optional duration in seconds to play the alerting tone for manual-answer email interactions."
        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_routing_queue",
            "attribute": "message_media_settings.sub_type_settings.enable_inactivity_timeout",
