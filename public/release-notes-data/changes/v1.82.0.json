            "resource": "genesyscloud_outbound_campaign",
            "attribute": "max_calls_per_agent_decimal",
            "change": "added",
            "summary": "Computed decimal max calls per agent value returned by the API; configure using max_calls_per_agent."
        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_outbound_campaign",
            "attribute": "agent_owned_column",
            "change": "added",
