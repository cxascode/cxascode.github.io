        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_routing_queue",
            "attribute": "callback_media_settings.sub_type_settings",
            "change": "removed",
            "summary": "Subtype-specific settings are not supported on callback media settings."
        },
        {
            "kind": "data_source_attribute",
            "resource": "genesyscloud_integration_action",
            "attribute": "integration_id",
            "change": "added",
            "summary": "Optional integration ID to disambiguate static data action lookups when names collide across integration instances."
        },
        {
            "kind": "data_source_behavior",
            "resource": "genesyscloud_integration_action",
            "attribute": null,
            "change": "updated",
            "summary": "Lookups filter by integration_id when provided; ambiguous name errors suggest setting integration_id."
        }
    ]
}
