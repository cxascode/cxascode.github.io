            "summary": "Execution frequency; valid values are onEachTrigger and oncePerDay."
        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_outbound_campaignrule",
            "attribute": "execution_settings.time_zone_id",
            "change": "added",
            "summary": "Time zone used when frequency is oncePerDay."
        },
        {
            "kind": "resource_behavior",
            "resource": "genesyscloud_outbound_campaignrule",
            "attribute": "campaign_rule_conditions",
            "change": "updated",
            "summary": "No longer unconditionally required; use either campaign_rule_conditions or condition_groups with campaign_rule_processing v2, enforced by plan validation."
        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_outbound_campaignrule",
            "attribute": "campaign_rule_conditions.condition_type",
