        {
            "kind": "resource_behavior",
            "resource": "genesyscloud_routing_queue",
            "attribute": null,
            "change": "updated",
            "summary": "When ignore_members is true, members are not read from the API or updated on apply."
        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_routing_sms_address",
            "attribute": "name",
            "change": "updated",
            "summary": "Now optional instead of required."
        },
        {
            "kind": "resource_behavior",
            "resource": "genesyscloud_routing_sms_address",
            "attribute": null,
            "change": "updated",
            "summary": "Create always sends address fields and sends name as an empty string when omitted."
        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_scripts",
            "attribute": "division_id",
            "change": "added",
            "summary": "Optional computed division for the script."
        },
        {
            "kind": "resource_behavior",
            "resource": "genesyscloud_team",
            "attribute": null,
            "change": "updated",
            "summary": "Partial failures when adding team members now fail the apply with per-member error details."
        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_user",
            "attribute": "addresses.phone_numbers.extension_pool_id",
            "change": "added",
            "summary": "Optional extension pool ID for phone extensions; populated on read when resolvable."
        },
        {
            "kind": "export_behavior",
            "resource": null,
            "attribute": null,
            "change": "updated",
            "summary": "Bulk export depends_on references to data sources now use the data. prefix."
        },
        {
            "kind": "export_behavior",
            "resource": "genesyscloud_user",
            "attribute": "addresses.phone_numbers.extension_pool_id",
            "change": "updated",
            "summary": "Bulk export resolves extension_pool_id to genesyscloud_telephony_providers_edges_extension_pool references."
        },
        {
            "kind": "export_behavior",
            "resource": "genesyscloud_routing_sms_address",
            "attribute": null,
            "change": "updated",
            "summary": "Bulk export may use postal_code as the block label when name is absent."
        }
    ]
}
