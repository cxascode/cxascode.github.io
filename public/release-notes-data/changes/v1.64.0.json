            "summary": "Optional flag to skip reading and updating queue members through Terraform; conflicts with members."
        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_routing_queue",
            "attribute": "members",
            "change": "updated",
            "summary": "Must use block syntax; attribute-style assignment is no longer supported. Diffs are suppressed when ignore_members is true."
        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_routing_queue",
            "attribute": "last_agent_routing_mode",
