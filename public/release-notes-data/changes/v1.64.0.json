            "summary": "Now optional and computed; must be set together with route_id when not using self_reference_route."
        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_routing_email_route",
            "attribute": "reply_email_address.route_id",
            "change": "updated",
            "summary": "Must be set together with domain_id when not using self_reference_route."
        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_routing_email_route",
            "attribute": "reply_email_address.self_reference_route",
            "change": "updated",
            "summary": "Validation now requires either this flag or both domain_id and route_id."
        },
        {
            "kind": "resource_behavior",
            "resource": "genesyscloud_routing_email_route",
            "attribute": null,
            "change": "updated",
            "summary": "Reply email address updates now include the route pattern in API requests."
        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_routing_queue",
            "attribute": "ignore_members",
