{
    "version": "v1.84.0",
    "previous": "v1.83.0",
    "changes": [
        {
            "kind": "provider_configuration",
            "resource": null,
            "attribute": "max_concurrent_pages",
            "change": "added",
            "summary": "New optional setting (default 1) to fetch list API pages in parallel during large reads; set GENESYSCLOUD_MAX_CONCURRENT_PAGES and increase token_pool_size alongside higher values."
        },
        {
            "kind": "provider_configuration",
            "resource": null,
            "attribute": "token_pool_size",
            "change": "updated",
            "summary": "Maximum allowed value increased from 20 to 50; description documents OAuth startup cost, rate-limit risk, and alignment with max_concurrent_pages."
        },
        {
            "kind": "resource_behavior",
            "resource": "genesyscloud_architect_grammar_language",
            "attribute": "voice_file_data.file_name",
            "change": "updated",
            "summary": "Plan diffs ignore Windows-style path separator and drive-letter differences because values are normalized before being sent to the API."
        },
        {
            "kind": "resource_behavior",
            "resource": "genesyscloud_architect_grammar_language",
            "attribute": "dtmf_file_data.file_name",
