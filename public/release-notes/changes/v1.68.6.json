            "resource": "genesyscloud_group",
            "attribute": "addresses",
            "change": "updated",
            "summary": "Exported configurations preserve empty addresses arrays instead of omitting them."
        },
        {
            "kind": "export_behavior",
            "resource": "genesyscloud_group",
            "attribute": "owner_ids",
            "change": "updated",
            "summary": "Exported configurations preserve empty owner_ids arrays instead of omitting them."
        },
        {
            "kind": "resource_behavior",
            "resource": "genesyscloud_journey_segment",
            "attribute": "assignment_expiration_days",
            "change": "updated",
            "summary": "Changes to assignment_expiration_days are now applied during resource updates."
        },
        {
            "kind": "resource_attribute",
            "resource": "genesyscloud_knowledge_document_variation",
            "attribute": "document_version",
            "change": "updated",
            "summary": "No longer settable in configuration; now computed only (was previously optional)."
        },
        {
